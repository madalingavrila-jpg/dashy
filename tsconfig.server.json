{
  "compilerOptions": {
    "target": "ES2024",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "types/**/*.ts",
    "lib/format.ts",
    "lib/isoWeek.ts",
    "lib/salesforce.ts",
    "lib/agent-segments.ts",
    "lib/weekly-stages.ts"
  ],
  "exclude": ["node_modules", "dist", "lib/targetConfig.ts", "lib/useDashboard.ts", "lib/api.ts"]
}
