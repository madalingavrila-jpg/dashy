{
  "name": "dashy",
  "version": "0.1.0",
  "private": true,
  "description": "Dashy — Ultimate Sales Dashboard — Boltable deployment",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "NODE_ENV=production next build && tsc -p tsconfig.server.json",
    "build:boltable": "npm run build",
    "start": "node dist/src/server.js",
    "start:server": "node dist/src/server.js",
    "dev": "next dev",
    "dev:server": "tsx src/server.ts",
    "lint": "next lint"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  }
}
