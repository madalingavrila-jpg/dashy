# Boltable / local server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
DASHY_CACHE_TTL_MS=60000

# Optional: published Google Sheet CSV/JSON URL (overrides data/dashboard.json)
# DASHBOARD_SHEET_URL=

# Optional: persist Settings target overrides to git on PUT /api/target-config (Boltable)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=boltable/dashy
# GITHUB_BRANCH=main

# Optional: set when frontend is hosted separately from the API
# NEXT_PUBLIC_API_BASE=
